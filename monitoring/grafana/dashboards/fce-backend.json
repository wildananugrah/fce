{
  "title": "FCE Backend",
  "uid": "fce-backend",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": { "from": "now-12h", "to": "now" },
  "timezone": "",
  "tags": ["fce", "backend"],
  "templating": {
    "list": [
      {
        "name": "app",
        "label": "app",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values(app)",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Unique Users",
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "count(count by (userId) (count_over_time({app=~\"$app\"} | regexp `\\[user:(?P<userId>[^\\]]+)\\]` | userId != \"anonymous\" [$__range])))",
          "queryType": "instant"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "unit": "none"
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Authenticated Requests",
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({app=~\"$app\"} |~ `\\] (GET|POST|PUT|DELETE|PATCH) ` | regexp `\\[user:(?P<userId>[^\\]]+)\\]` | userId != \"anonymous\" [$__range]))",
          "queryType": "instant"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" },
          "unit": "none"
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "table",
      "title": "Users",
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (userId) (count_over_time({app=~\"$app\"} | regexp `\\[user:(?P<userId>[^\\]]+)\\]` | userId != \"anonymous\" [$__range])))",
          "queryType": "instant",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "userId" }, "properties": [{ "id": "displayName", "value": "User ID" }] },
          { "matcher": { "id": "byName", "options": "Value" }, "properties": [{ "id": "displayName", "value": "Requests" }] }
        ]
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Total Requests",
      "gridPos": { "h": 5, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({app=~\"$app\"} |~ `\\] (GET|POST|PUT|DELETE|PATCH) ` [$__range]))",
          "queryType": "instant"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "purple" },
          "unit": "none"
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Error Count",
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({app=~\"$app\"} |~ `\\[ERROR\\]` [$__range]))",
          "queryType": "instant"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "unit": "none",
          "noValue": "0"
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Unique Users Over Time",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 5 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (userId) (count_over_time({app=~\"$app\"} | regexp `\\[user:(?P<userId>[^\\]]+)\\]` | userId != \"anonymous\" [$__interval]))",
          "legendFormat": "{{userId}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60,
            "stacking": { "mode": "normal", "group": "A" }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 7,
      "type": "barchart",
      "title": "Top Active Users",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 5 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (userId) (count_over_time({app=~\"$app\"} | regexp `\\[user:(?P<userId>[^\\]]+)\\]` | userId != \"anonymous\" [$__range])))",
          "queryType": "instant",
          "legendFormat": "{{userId}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-BlPu" }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "xTickLabelRotation": 0,
        "legend": { "displayMode": "hidden", "showLegend": false }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Log Volume (per minute)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 13 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (level) (count_over_time({app=~\"$app\"} | regexp `\\[(?P<level>INFO|WARN|ERROR|DEBUG)\\]` [1m]))",
          "legendFormat": "{{level}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 70, "stacking": { "mode": "normal", "group": "A" } }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "INFO" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "WARN" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] },
          { "matcher": { "id": "byName", "options": "ERROR" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }
        ]
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "HTTP Requests by Status",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 21 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (count_over_time({app=~\"$app\"} | regexp `(?P<method>GET|POST|PUT|DELETE|PATCH) \\S+ (?P<status>\\d{3})` [1m]))",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 70, "stacking": { "mode": "normal", "group": "A" } }
        },
        "overrides": []
      }
    },
    {
      "id": 10,
      "type": "table",
      "title": "Top Endpoints",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 21 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(15, sum by (method, uri) (count_over_time({app=~\"$app\"} | regexp `(?P<method>GET|POST|PUT|DELETE|PATCH) (?P<uri>\\S+) \\d{3}` [$__range])))",
          "queryType": "instant",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "method" }, "properties": [{ "id": "displayName", "value": "Method" }, { "id": "custom.width", "value": 90 }] },
          { "matcher": { "id": "byName", "options": "uri" }, "properties": [{ "id": "displayName", "value": "Endpoint" }] },
          { "matcher": { "id": "byName", "options": "Value" }, "properties": [{ "id": "displayName", "value": "Count" }, { "id": "custom.width", "value": 90 }] }
        ]
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Response Time",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 29 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "quantile_over_time(0.50, {app=~\"$app\"} |~ ` \\d+ms$` | regexp ` (?P<duration_ms>\\d+)ms$` | unwrap duration_ms [1m])",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "quantile_over_time(0.95, {app=~\"$app\"} |~ ` \\d+ms$` | regexp ` (?P<duration_ms>\\d+)ms$` | unwrap duration_ms [1m])",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "expr": "quantile_over_time(0.99, {app=~\"$app\"} |~ ` \\d+ms$` | regexp ` (?P<duration_ms>\\d+)ms$` | unwrap duration_ms [1m])",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" },
        "overrides": []
      }
    },
    {
      "id": 12,
      "type": "logs",
      "title": "All Logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 37 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "{app=~\"$app\"}"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none",
        "enableLogDetails": true
      }
    },
    {
      "id": 13,
      "type": "row",
      "title": "--- Job Queue Monitoring ---",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 47 },
      "panels": []
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Queue Depth",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 48 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({app=~\"$app\"} |~ `\"Job queued\"|job enqueued` [$__range]))",
          "queryType": "instant"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 10 }, { "color": "red", "value": 50 }] },
          "noValue": "0"
        }
      }
    },
    {
      "id": 15,
      "type": "stat",
      "title": "Active Jobs",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 48 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({app=~\"$app\"} |~ `generation started|extraction started|scraping started|recompute started` [5m])) - sum(count_over_time({app=~\"$app\"} |~ `generation completed|generation failed|extraction completed|extraction failed|scraping completed|scraping failed|recompute completed|recompute failed` [5m]))",
          "queryType": "instant"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "noValue": "0"
        }
      }
    },
    {
      "id": 16,
      "type": "stat",
      "title": "Completed (24h)",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 48 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({app=~\"$app\"} |~ `generation completed|extraction completed|scraping completed|recompute completed` [24h]))",
          "queryType": "instant"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" },
          "noValue": "0"
        }
      }
    },
    {
      "id": 17,
      "type": "stat",
      "title": "Failed (24h)",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 48 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({app=~\"$app\"} |~ `generation failed|extraction failed|scraping failed|recompute failed` [24h]))",
          "queryType": "instant"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] },
          "noValue": "0"
        }
      }
    },
    {
      "id": 18,
      "type": "timeseries",
      "title": "Job Throughput",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 53 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({app=~\"$app\"} |~ `generation completed|extraction completed|scraping completed|recompute completed` [$__interval]))",
          "legendFormat": "Completed"
        },
        {
          "refId": "B",
          "expr": "sum(count_over_time({app=~\"$app\"} |~ `generation failed|extraction failed|scraping failed|recompute failed` [$__interval]))",
          "legendFormat": "Failed"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 70 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Completed" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "Failed" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }
        ]
      }
    },
    {
      "id": 19,
      "type": "timeseries",
      "title": "HTTP Response Time (p50/p95/p99)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 53 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "quantile_over_time(0.50, {app=~\"$app\"} |~ ` \\d+ms$` | regexp ` (?P<duration_ms>\\d+)ms$` | unwrap duration_ms [5m])",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "quantile_over_time(0.95, {app=~\"$app\"} |~ ` \\d+ms$` | regexp ` (?P<duration_ms>\\d+)ms$` | unwrap duration_ms [5m])",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "expr": "quantile_over_time(0.99, {app=~\"$app\"} |~ ` \\d+ms$` | regexp ` (?P<duration_ms>\\d+)ms$` | unwrap duration_ms [5m])",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] }
    },
    {
      "id": 20,
      "type": "barchart",
      "title": "Jobs by Type",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 61 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (jobType) (count_over_time({app=~\"$app\"} | regexp `(?P<jobType>Content generation|Campaign generation|Topic generation|Brand scraping|Document extraction|Recommendation recompute) (completed|failed)` [$__range]))",
          "queryType": "instant",
          "legendFormat": "{{jobType}}"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "legend": { "displayMode": "hidden", "showLegend": false }
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "continuous-GrYlRd" } },
        "overrides": []
      }
    },
    {
      "id": 21,
      "type": "logs",
      "title": "Recent Failed Jobs",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 61 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "{app=~\"$app\"} |~ `generation failed|extraction failed|scraping failed|recompute failed`"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none",
        "enableLogDetails": true
      }
    }
  ]
}
