# Database
POSTGRES_USER=fce
POSTGRES_PASSWORD=fce_secret
POSTGRES_DB=fce_dashboard
DATABASE_URL=postgresql://fce:fce_secret@localhost:5433/fce_dashboard

# Backend
# Force the Node/Bun process into UTC so node-postgres parses Prisma's
# `timestamp without time zone` columns as UTC (matching how they're stored).
# Without this, running on a non-UTC host (e.g. a Mac in WIB) shifts every
# createdAt/updatedAt on read. Do not change unless you also migrate columns
# to `timestamptz`. Browsers still localize for display on top of this.
TZ=UTC
PORT=3001
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_REFRESH_SECRET=change-me-to-another-random-64-char-string
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# AI Providers
AI_PROVIDER=anthropic
AI_CONTENT_PROVIDER=
AI_CAMPAIGN_PROVIDER=
AI_TOPIC_PROVIDER=
AI_BRAND_SCRAPER_PROVIDER=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=fce-uploads

# pgAdmin (docker-compose service, reachable via nginx at pg.<domain>)
PGADMIN_DEFAULT_EMAIL=admin@floothink.com
PGADMIN_DEFAULT_PASSWORD=changeme

# Per-user quotas applied at user creation. Tune per-user afterwards via SQL,
# e.g. `UPDATE users SET max_projects = 10 WHERE email = 'x@y.com';`.
USER_DEFAULT_MAX_WORKSPACES=1
USER_DEFAULT_MAX_PROJECTS=3

# Observability (Phase 6)
SERVICE_NAME=fce-backend
LOKI_URL=http://localhost:3101
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4319

# Email
# Pick a transport: "resend", "smtp", or "noop" (default — logs to stdout,
# never delivers; dev only). Switching is a restart; no code change.
EMAIL_PROVIDER=noop
# Used by every provider: display address on outgoing mail.
EMAIL_FROM=onboarding@resend.dev

# Resend (EMAIL_PROVIDER=resend)
RESEND_API_KEY=

# SMTP (EMAIL_PROVIDER=smtp) — works with Mailjet (in-v3.mailjet.com:587),
# Google (smtp.gmail.com:587, use an app password), AWS SES, Mailgun, etc.
SMTP_HOST=
SMTP_PORT=587
# true for port 465 (implicit TLS); false for 587 (STARTTLS — Mailjet + Gmail)
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

APP_URL=http://localhost:5173
INVITATION_TOKEN_EXPIRY=7d
# Expiry for email verification tokens issued at signup + by /resend-verification.
EMAIL_VERIFICATION_TOKEN_EXPIRY=24h

# Trash retention — soft-archived brands/products/topics/content older than
# this are hard-deleted by the hourly archive-sweep pg-boss worker.
ARCHIVE_TTL_DAYS=30

# Frontend (build-time)
VITE_API_URL=http://localhost:3001

# Chat
AI_CHAT_PROVIDER=
CHAT_HISTORY_WINDOW=20
